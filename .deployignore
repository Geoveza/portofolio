.vscode\
.idea\
*.swp
*.swo
*~
.DS_Store

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Build files (if any)
dist\
build\

# Documentation (keep README.md)
DEPLOY*.md
SECURITY*.md

# GitHub
.github\
